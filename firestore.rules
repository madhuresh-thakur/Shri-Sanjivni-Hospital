rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'admin123@gmail.com' || request.auth.uid == 'ubOIFpjYDjgPeueg8l60EQcAD5S2');
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
      );

      function isValidUser(data) {
        return (data.uid == request.auth.uid || isAdmin())
          && data.email is string && data.email.size() <= 100
          && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
          && data.keys().hasAll(['uid', 'email', 'createdAt'])
          && data.keys().size() <= 4;
      }
    }

    // --- Bookings Collection ---
    match /bookings/{bookingId} {
      // Admin can see everything, users only see theirs
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidBooking(incoming());
      
      // Admin can update any status, users only their specific fields
      allow update: if (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid)) && (
        isValidBooking(incoming())
      );

      allow delete: if isAdmin();

      function isValidBooking(data) {
        return (data.userId == request.auth.uid || isAdmin())
          && data.departmentId is string && data.departmentId.size() <= 50
          && data.doctorId is string && data.doctorId.size() <= 50
          && data.date is string && data.date.size() <= 50
          && (data.status in ['pending', 'confirmed', 'cancelled'])
          && data.keys().hasAll(['userId', 'departmentId', 'doctorId', 'date', 'status', 'createdAt'])
          && data.keys().size() <= 10;
      }
    }
  }
}
